# Copy to apps/mobile/.env (never commit .env)

# Same Supabase project as the website — must use EXPO_PUBLIC_ (not NEXT_PUBLIC_)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
# Copy values from root .env.local, but rename NEXT_PUBLIC_ → EXPO_PUBLIC_

# Next.js site URL — the app calls mobile API routes on this host
# Simulator: http://localhost:3000
# Physical phone: http://YOUR_COMPUTER_LAN_IP:3000  (e.g. http://192.168.1.42:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Expo push (required for job alerts) — run: npx eas login && npx eas init
# Then copy projectId from app.json extra.eas.projectId here, or leave eas init to write app.json.
# EXPO_PUBLIC_EAS_PROJECT_ID=

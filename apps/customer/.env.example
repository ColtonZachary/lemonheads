# Copy to apps/customer/.env (never commit .env)

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Next.js site URL — customer app calls /api/mobile/customer/*
# Simulator: http://localhost:3000
# Physical phone: http://YOUR_COMPUTER_LAN_IP:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

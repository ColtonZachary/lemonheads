# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# ── Stripe (booking card capture)
# Dashboard → Developers → API keys — use test keys locally first.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ── Resend (optional — booking/contact emails log to console when unset)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Lemonhead's <onboarding@resend.dev>
# RESEND_TO_EMAIL=info@lemonheadsdetail.com

# ── Supabase (photos now; auth + invoices later)
# Settings → API Keys → publishable + secret
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy name still works:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (upload script) — never expose to the browser
# Server-only — required to save bookings to Supabase (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=
